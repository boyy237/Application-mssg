<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:gravity="end"
    android:orientation="horizontal"
    android:paddingStart="60dp"
    android:paddingEnd="8dp">

    <LinearLayout
        android:id="@+id/bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_sent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <!-- Texte du message — s'étire sur autant de lignes que nécessaire -->
        <TextView
            android:id="@+id/textPlain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:maxWidth="240dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            tools:text="Bonjour, comment tu vas ?" />

        <!-- Ligne du bas : heure + icône lu -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_faint"
                android:textSize="11sp"
                tools:text="14:02" />

            <ImageView
                android:id="@+id/iconReadStatus"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_done"
                app:tint="@color/text_faint" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
