<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="60dp">

    <LinearLayout
        android:id="@+id/bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_received"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <!-- Nom de l'expéditeur (utile pour les groupes) -->
        <TextView
            android:id="@+id/textSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:letterSpacing="0.04"
            android:textColor="@color/bob"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="Bob" />

        <!-- Texte du message — s'étire sur autant de lignes que nécessaire -->
        <TextView
            android:id="@+id/textPlain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:maxWidth="240dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            tools:text="Ça va bien merci, et toi ?" />

        <!-- Heure -->
        <TextView
            android:id="@+id/textTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_faint"
            android:textSize="11sp"
            tools:text="14:03" />

    </LinearLayout>

</LinearLayout>
